# fxmarketapi.com
DISCORD_WEBHOOK_URL=your-dicord-webhook-url # looks like https://discord.com/api/webhooks/(...)

FOREX_API_KEY=your-api-key-from-fxmarketapi
FOREX_PROVIDER=fxmarketapi

FOREX_SHORT_MOVING_AVG=42 # INT
FOREX_LONG_MOVING_AVG=150 # INT

MY_NAME=World

# Comma-separated — delete any pair to turn it off (batched 3 at a time automatically)
# EURUSD   Euro
# GBPUSD   British Pound
# CADUSD   Canadian Dollar (USD value of 1 CAD)
# AUDUSD   Australian Dollar
# NZDUSD   New Zealand Dollar
# USDJPY   Yen per 1 US Dollar (shown as ¥)
# USDCHF   Swiss Franc per 1 US Dollar (uncomment to enable)
FOREX_PAIRS=EURUSD,GBPUSD,CADUSD,AUDUSD,NZDUSD,USDJPY

# Future: RUN_MODE=service | github_actions